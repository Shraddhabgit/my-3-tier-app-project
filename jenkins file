    stage('Frontend PUSH to ECR') {
      steps {
         sh '''
      # Login to ECR
      aws ecr get-login-password --region ap-south-1 | \
        docker login --username AWS --password-stdin 269744751587.dkr.ecr.ap-south-1.amazonaws.com

      # Tag image
      docker tag my-frontend:latest \
        269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-3-tier-app-frontend:latest

      # Push image
      docker push 269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-3-tier-app-frontend:latest
    '''
      }
    }
    stage('Backend Push to ECR'){
        steps{
            sh '''
            docker tag my-backend:latest \
        269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-3-tier-app-backend:latest

      # Push image
      docker push 269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-3-tier-app-backend:latest
    '''
        }
    }

stage('Update K8s Manifests') {
    steps {
        sh '''
         cd "$WORKSPACE"
                # Update the YAML file directly
                 sed -i "s|image: .*frontend.*|image: 269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-frontend:latest|" k8s/jerney.yaml
                sed -i "s|image: .*backend.*|image: 269744751587.dkr.ecr.ap-south-1.amazonaws.com/my-backend:latest|" k8s/jerney.yaml
        '''

            
withCredentials([usernamePassword(credentialsId: 'github-creds', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
  sh '''
    git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/Shraddhabgit/my-3-tier-app-project.git
    git add k8s/jerney.yaml
   git commit -m "Update images in single YAML"
    git push origin main
  '''
}
    }
}
  }
}






