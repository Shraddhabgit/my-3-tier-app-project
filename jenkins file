pipeline {
  agent none
  stages {
    stage('checkout') {
    agent { docker { image 'alpine/git:latest' } }
      steps {
    git branch: 'main',
        url: 'https://github.com/Shraddhabgit/my-3-tier-app-project',
        credentialsId: 'github-cred'
  }
    }

 stage('sonarqube'){
   agent { docker { image 'sonarsource/sonar-scanner-cli:latest' } }
        steps{
            withSonarQubeEnv('sonarqube') {   // Must match the server name in Jenkins config
            withCredentials([string(credentialsId: 'sonar-cred', variable: 'SONAR_TOKEN')]) {
                sh '''
                  cd $WORKSPACE
                  sonar-scanner \
                    -Dsonar.projectKey=3-tier-app \
                    -Dsonar.sources=. \
                    -Dsonar.host.url=${SONAR_HOST_URL} \
                    -Dsonar.token=${SONAR_TOKEN}
                '''
    sh 'echo ${SONAR_HOST_URL}'
            }
        }
}
}
stage('Quality Gate') {
 agent { docker { image 'openjdk:11-jre-slim' } }
            steps {
                script {
                    // This will wait for SonarQube to finish analysis
                    // and fail the pipeline if the Quality Gate fails
                    def qg = waitForQualityGate abortPipeline: true
                    echo "Quality Gate status: ${qg.status}"
                }
            }
        }

    stage('Frontend docker build ') {
     agent { docker { 
             image 'docker:20.10' 
             args '-v /var/run/docker.sock:/var/run/docker.sock'
            } }
      steps {
        sh 'docker build -t my-frontend:latest -f frontend/Dockerfile frontend/'
      }
    }
    stage('Backend docker build ') {
     agent { docker {
       image 'docker:20.10'  
        args '-v /var/run/docker.sock:/var/run/docker.sock'
        } }
      steps {
        sh 'docker build -t my-backend:latest -f backend/Dockerfile backend/'
      }
    }
